---
// src/pages/dashboard/pendaftaran.astro
import Layout from "../../layouts/Layout.astro";
import { getAllUsers } from "../../lib/db";

const usersResult = await getAllUsers();
const allUsers = usersResult.success ? usersResult.data : [];

// Get unique years from data
const dbYears = [
  ...new Set(
    allUsers.map((user: any) => user.tahun_pendaftaran || user.tahun_ppdb),
  ),
].filter(Boolean) as string[];

// Generate next 10 years based on current year (format like "2026/2027")
const currentYear = new Date().getFullYear();
const futureYears = Array.from({ length: 11 }, (_, i) => {
  const start = currentYear + i;
  return `${start}/${start + 1}`;
});

// Combine and deduplicate
const uniqueYears = [...new Set([...dbYears, ...futureYears])].sort();

// Get current year from URL or default to "Semua"
const url = new URL(Astro.request.url);
const selectedYear = url.searchParams.get("tahun") || "Semua";

// Filter users by year if selected
const filteredUsers =
  selectedYear === "Semua"
    ? allUsers
    : allUsers.filter(
        (user: any) =>
          (user.tahun_pendaftaran || user.tahun_ppdb) === selectedYear,
      );

// Calculate statistics
const calculateStats = (users: any[]) => {
  const total = users.length;
  const pending = users.filter(
    (u) => !u.status || u.status === "pending",
  ).length;
  const review = users.filter((u) => u.status === "review").length;
  const approved = users.filter((u) => u.status === "approved").length;
  const rejected = users.filter((u) => u.status === "rejected").length;

  return { total, pending, review, approved, rejected };
};

const stats = calculateStats(filteredUsers);
const allStats = calculateStats(allUsers);
---

<Layout title="Admin Pendaftaran">
  <div class="container min-h-screen mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-6">
      Admin Panel - Pendaftaran Siswa Baru
    </h1>

    <div class="flex justify-between items-center mb-6">
      <button
        id="logoutBtn"
        class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition text-sm font-medium flex items-center"
      >
        <svg
          class="w-4 h-4 mr-2"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"
          ></path>
        </svg>
        Logout
      </button>

      <a
        href="/dashboard"
        class="text-sm text-primary hover:underline flex items-center gap-1"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"><path d="m15 18-6-6 6-6"></path></svg
        >
        Kembali ke Dashboard
      </a>
    </div>

    <!-- Filter Section -->
    <div class="bg-body rounded-xl shadow-lg p-6 mb-6">
      <div
        class="flex flex-col md:flex-row md:items-center justify-between gap-4"
      >
        <!-- Year Filter -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2"
            >Filter Berdasarkan Tahun Pendaftaran</label
          >
          <div class="relative">
            <select
              id="yearFilter"
              class="appearance-none bg-surface border border-gray-300 text-gray-700 py-2 pl-4 pr-10 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary transition font-medium w-full sm:w-auto cursor-pointer"
            >
              <option value="Semua" selected={selectedYear === "Semua"}>Semua Tahun</option>
              {uniqueYears.map((year) => (
                <option value={year} selected={selectedYear === year}>{year}</option>
              ))}
            </select>
            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-gray-700">
              <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg>
            </div>
          </div>
        </div>

        <!-- Export Button -->
        <div class="flex flex-wrap items-end gap-3">
          <button
            id="exportBtn"
            class="bg-green-700 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-green-800"
          >
            Export CSV
          </button>
        </div>
      </div>

      <!-- Current Filter Info -->
      <div class="mt-4 text-sm text-gray-600">
        <p>
          Menampilkan data untuk:
          <span class="font-medium ml-1">
            {selectedYear === "Semua" ? "Semua Tahun" : `Tahun ${selectedYear}`}
          </span>
        </p>
      </div>
    </div>
    <!-- Statistics Cards -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
      <!-- Total Card -->
      <div class="bg-body rounded-xl shadow-lg p-6 border-t-4 border-blue-500">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-gray-600">Total Pendaftar</p>
            <p class="text-2xl font-bold text-gray-800">{stats.total}</p>
          </div>
          <div class="p-3 bg-blue-100 rounded-lg">
            <svg
              class="w-6 h-6 text-secondary"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
              ></path>
            </svg>
          </div>
        </div>
        <p class="text-xs text-gray-500 mt-2">
          {selectedYear === "Semua" ? "Semua tahun" : `Tahun ${selectedYear}`}
        </p>
      </div>

      <!-- Pending Card -->
      <div
        class="bg-body rounded-xl shadow-lg p-6 border-t-4 border-yellow-500"
      >
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-gray-600">Menunggu</p>
            <p class="text-2xl font-bold text-gray-800">{stats.pending}</p>
          </div>
          <div class="p-3 bg-yellow-100 rounded-lg">
            <svg
              class="w-6 h-6 text-yellow-600"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
        </div>
        <p class="text-xs text-gray-500 mt-2">
          {
            stats.total > 0
              ? `${Math.round((stats.pending / stats.total) * 100)}% dari total`
              : "Tidak ada data"
          }
        </p>
      </div>

      <!-- Approved Card -->
      <div class="bg-body rounded-xl shadow-lg p-6 border-t-4 border-green-500">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-gray-600">Diterima</p>
            <p class="text-2xl font-bold text-gray-800">{stats.approved}</p>
          </div>
          <div class="p-3 bg-green-100 rounded-lg">
            <svg
              class="w-6 h-6 text-green-600"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
        </div>
        <p class="text-xs text-gray-500 mt-2">
          {
            stats.total > 0
              ? `${Math.round((stats.approved / stats.total) * 100)}% dari total`
              : "Tidak ada data"
          }
        </p>
      </div>

      <!-- Rejected Card -->
      <div class="bg-body rounded-xl shadow-lg p-6 border-t-4 border-red-500">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm font-medium text-gray-600">Ditolak</p>
            <p class="text-2xl font-bold text-gray-800">{stats.rejected}</p>
          </div>
          <div class="p-3 bg-red-100 rounded-lg">
            <svg
              class="w-6 h-6 text-red-600"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"
              ></path>
            </svg>
          </div>
        </div>
        <p class="text-xs text-gray-500 mt-2">
          {
            stats.total > 0
              ? `${Math.round((stats.rejected / stats.total) * 100)}% dari total`
              : "Tidak ada data"
          }
        </p>
      </div>
    </div>
    <!-- Users Table -->
    <h2 class="text-xl font-bold mb-4">Daftar Pendaftar</h2>
    <div class="bg-body rounded-xl shadow-lg mb-6">
      {
        filteredUsers.length > 0 ? (
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
              <thead class="bg-gray-50">
                <tr class="*:p-3 text-left text-xs text-gray-500 uppercase tracking-wider">
                  <th class="font-medium">ID Pendaftaran</th>
                  <th class="font-medium">Tanggal</th>
                  <th class="font-medium">Nama</th>
                  <th class="font-medium">Status</th>
                  <th class="font-medium">Aksi</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-200">
                {filteredUsers.map((user: any) => (
                  <tr class="hover:bg-gray-50 transition-colors">
                    <td class="pl-3 py-4 text-sm font-mono text-gray-900">
                      {user.kode_pendaftaran}
                    </td>
                    <td class="px-3 py-2 whitespace-nowrap">
                      <div class="text-sm text-gray-900">
                        {user.created_at
                          ? new Date(user.created_at).toLocaleDateString(
                              "id-ID",
                            )
                          : "-"}
                      </div>
                    </td>
                    <td class="text-sm py-2 px-3">{user.nama_lengkap}</td>
                    <td class="px-3 py-2 whitespace-nowrap">
                      <span
                        class={`px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full status-badge capitalize ${
                          user.status === "approved"
                            ? "bg-green-100 text-green-800"
                            : user.status === "rejected"
                              ? "bg-red-100 text-red-800"
                              : user.status === "review"
                                ? "bg-blue-100 text-blue-800"
                                : "bg-yellow-100 text-yellow-800"
                        }`}
                      >
                        {user.status || "pending"}
                      </span>
                    </td>
                    <td class="px-3 py-2 whitespace-nowrap text-sm font-medium flex gap-3">
                      <a
                        href={`/dashboard/pendaftaran/detail?id=${user.id}`}
                        class="text-secondary hover:underline"
                      >
                        Detail
                      </a>
                      <a
                        href={`/api/pendaftaran/update-status?id=${user.id}&status=approved`}
                        class="text-green-600 hover:underline action-approve"
                      >
                        Terima
                      </a>
                      <a
                        href={`/api/pendaftaran/update-status?id=${user.id}&status=rejected`}
                        class="text-red-600 hover:underline action-reject"
                      >
                        Tolak
                      </a>
                      <a
                        href={`/api/pendaftaran/delete?id=${user.id}`}
                        class="text-gray-600 hover:underline action-delete"
                      >
                        Hapus
                      </a>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        ) : (
          <div class="p-8 text-center">
            <svg
              class="mx-auto h-12 w-12 text-gray-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
              />
            </svg>
            <h3 class="mt-2 text-sm font-medium text-gray-900">
              Tidak ada pendaftar
            </h3>
            <p class="mt-1 text-sm text-gray-500">
              Belum ada data pendaftaran untuk filter ini.
            </p>
          </div>
        )
      }
    </div>

    <!-- Footer Summary -->
    <div class="mt-6 text-center text-sm text-gray-500">
      <p>
        {
          selectedYear === "Semua"
            ? `Menampilkan semua data dari ${uniqueYears.length} tahun akademik`
            : `Data hanya untuk tahun akademik ${selectedYear}`
        }
      </p>
      <p class="mt-1">
        Terakhir diupdate: {
          new Date().toLocaleDateString("id-ID", {
            weekday: "long",
            year: "numeric",
            month: "long",
            day: "numeric",
            hour: "2-digit",
            minute: "2-digit",
          })
        }
      </p>
    </div>
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", function () {
      // Logout function
      const logoutBtn = document.getElementById("logoutBtn");
      if (logoutBtn) {
        logoutBtn.addEventListener("click", async function () {
          if (confirm("Apakah Anda yakin ingin logout?")) {
            try {
              await fetch("/api/admin/logout", { method: "POST" });
              window.location.href = "/dashboard/login";
            } catch (error) {
              alert("Gagal logout. Silakan coba lagi.");
            }
          }
        });
      }

      // Konfirmasi sebelum update status
      document
        .querySelectorAll(".action-approve, .action-reject, .action-delete")
        .forEach((link) => {
          link.addEventListener("click", function (e) {
            let action = "";
            if (this.classList.contains("action-approve")) {
              action = "menerima";
            } else if (this.classList.contains("action-reject")) {
              action = "menolak";
            } else if (this.classList.contains("action-delete")) {
              action = "MENGHAPUS PERMANEN";
            }
            const confirmed = confirm(
              `Apakah Anda yakin ingin ${action} pendaftaran ini?`,
            );

            if (!confirmed) {
              e.preventDefault();
            }
          });
        });

      // Export CSV
      const exportBtn = document.getElementById("exportBtn");
      if (exportBtn) {
        exportBtn.addEventListener("click", () => {
          const tahun = new URLSearchParams(window.location.search).get(
            "tahun",
          );
          let url = "/api/pendaftaran/export?";
          if (tahun && tahun !== "Semua") {
            url += `tahun=${encodeURIComponent(tahun)}`;
          }
          window.location.href = url;
        });
      }

      // Year Filter Dropdown logic
      const yearFilter = document.getElementById("yearFilter");
      if (yearFilter) {
        yearFilter.addEventListener("change", function(e) {
          const selectedValue = (e.target as HTMLSelectElement).value;
          window.location.href = '?tahun=' + encodeURIComponent(selectedValue);
        });
      }
    });
  </script>
</Layout>
