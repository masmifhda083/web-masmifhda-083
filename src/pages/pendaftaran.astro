---
import Layout from "../layouts/Layout.astro";
import Year from "../components/Year.astro";
import { getCollection } from "astro:content";

// Ambil data sekolah dari Tina CMS
const pendaftaranData = await getCollection("pendaftaran");
const settings = pendaftaranData[0]?.data?.datappdb || {
  schoolName: "",
  ppdbAlias: "",
  logoUrl: "",
  coverImageUrl: "",
  primaryColor: "",
  secondaryColor: "",
  academicYear: "",
  registrationPeriod: "",
  registrationOpen: true,
};
---

<Layout title="Pendaftaran Siswa Baru">
  <section
    class="relative overflow-hidden bg-cover bg-center before:content-[''] before:absolute before:opacity-70 before:z-10 before:w-full before:h-full"
    style={`background-image: url('${settings.coverImageUrl || ""}'); --tw-bg-opacity: 0.7;`}
  >
    <div
      class="absolute inset-0 opacity-90"
      style={`background-color: ${settings.primaryColor || "#1e40af"};`}
    >
    </div>
    <div class="container mx-auto px-4 py-12 md:py-16 relative z-10">
      <div class="flex flex-col md:flex-row items-center justify-between gap-8">
        <!-- Logo dan Nama Sekolah -->
        <div
          class="flex flex-col md:flex-row justify-center md:justify-start items-center gap-4 text-center md:text-left"
        >
          {
            settings.logoUrl && (
              <div class="w-20 h-20 md:w-24 md:h-24 bg-surface rounded-full p-2 shadow-lg">
                <img
                  src={settings.logoUrl}
                  alt={`Logo ${settings.schoolName}`}
                  class="w-full h-full object-contain"
                />
              </div>
            )
          }
          <div class="text-surface">
            {
              settings.ppdbAlias && (
                <p class="text-sm font-medium">{settings.ppdbAlias}</p>
              )
            }
            <h1 class="text-2xl md:text-4xl font-bold mb-2">
              {settings.schoolName}
            </h1>
            <p class="text-lg mt-2">Tahun Ajaran: {settings.academicYear}</p>
            <p class="text-lg mt-2">{settings.registrationPeriod}</p>
          </div>
        </div>

        <!-- Status Pendaftaran -->
        <div
          class={`inline-flex flex-col md:flex-row items-center px-6 py-3 rounded-full shadow-lg ${settings.registrationOpen ? "bg-green-100 text-green-800" : "bg-red-100 text-red-800"}`}
        >
          <div class="flex items-center">
            <div
              class={`w-3 h-3 rounded-full mr-3 ${settings.registrationOpen ? "bg-green-500 animate-pulse" : "bg-red-500"}`}
            >
            </div>
            <div class="font-bold text-sm">
              Pendaftaran {settings.registrationOpen ? "DIBUKA" : "DITUTUP"}
            </div>
          </div>
          <div class="ml-3 text-xs">
            {
              settings.registrationOpen
                ? "🏃 Yuk Daftar Sekarang!"
                : "⏳ Tunggu Periode Berikutnya"
            }
          </div>
        </div>
      </div>
    </div>
  </section>
  <div class="container mx-auto px-4 py-8">
    <!-- Navigation Tabs -->
    <div class="flex border-b border-gray-200 mb-8">
      <a
        href="/pendaftaran"
        class="p-3 text-sm md:text-lg font-medium text-blue-600 border-b-2 border-blue-600"
      >
        Form Pendaftaran
      </a>
      <a
        href="/pendaftaran/status"
        class="p-3 text-sm md:text-lg font-medium text-gray-500 hover:text-blue-600"
      >
        Cek Status
      </a>
    </div>

    <h1
      class="text-xl md:text-3xl font-bold text-center max-w-4xl mx-auto mb-8 text-gray-800"
    >
      Formulir Pendaftaran {
        settings.ppdbAlias && <span>{settings.ppdbAlias}</span>
      }
      <span style={`color: ${settings.primaryColor || "#2563eb"};`}
        ><Year /></span
      >
    </h1>

    <!-- Form sama dengan sebelumnya, tapi adjust endpoint API -->
    <form id="registrationForm" class="space-y-8 max-w-4xl mx-auto">
      <!-- Informasi Pendaftaran -->
      <section class="bg-white p-6 rounded-xl shadow-lg border border-gray-100">
        <h2
          class="text-xl font-semibold mb-4 text-gray-800 border-l-4 border-secondary pl-3"
        >
          Informasi Pendaftaran
        </h2>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">
              Tahun Pendaftaran <span class="text-red-500">*</span>
            </label>
            <select
              name="tahun_pendaftaran"
              id="tahun_pendaftaran"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-secondary focus:border-secondary transition duration-200"
            >
              <option value="">Pilih Tahun</option>
              {
                Array.from({ length: 5 }).map((_, i) => {
                  const year = new Date().getFullYear() + i;
                  return (
                    <option value={`${year}/${year + 1}`}>
                      {year}/{year + 1}
                    </option>
                  );
                })
              }
            </select>
          </div>
        </div>
      </section>

      <!-- Data Pribadi Peserta Didik -->
      <section class="bg-white p-6 rounded-xl shadow-lg border border-gray-100">
        <h2
          class="text-xl font-semibold mb-6 text-gray-800 border-l-4 border-secondary pl-3"
        >
          Data Pribadi Peserta Didik
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <!-- Nama Lengkap -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">
              Nama Lengkap <span class="text-red-500">*</span>
            </label>
            <input
              type="text"
              name="nama_lengkap"
              required
              placeholder="Masukkan nama lengkap"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-secondary focus:border-secondary transition duration-200"
            />
          </div>

          <!-- Nama Panggilan -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">
              Nama Panggilan <span class="text-red-500">*</span>
            </label>
            <input
              type="text"
              name="nama_panggilan"
              required
              placeholder="Masukkan nama panggilan"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-secondary focus:border-secondary transition duration-200"
            />
          </div>

          <!-- Tempat Lahir -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">
              Tempat Lahir <span class="text-red-500">*</span>
            </label>
            <input
              type="text"
              name="tempat_lahir"
              required
              placeholder="Kota tempat lahir"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-secondary focus:border-secondary transition duration-200"
            />
          </div>

          <!-- Tanggal Lahir -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">
              Tanggal Lahir <span class="text-red-500">*</span>
            </label>
            <input
              type="date"
              name="tanggal_lahir"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-secondary focus:border-secondary transition duration-200"
            />
          </div>

          <!-- Jenis Kelamin -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">
              Jenis Kelamin <span class="text-red-500">*</span>
            </label>
            <select
              name="jenis_kelamin"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-secondary focus:border-secondary transition duration-200"
            >
              <option value="">Pilih Jenis Kelamin</option>
              <option value="Laki-laki">Laki-laki</option>
              <option value="Perempuan">Perempuan</option>
            </select>
          </div>

          <!-- Agama -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">
              Agama <span class="text-red-500">*</span>
            </label>
            <select
              name="agama"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-secondary focus:border-secondary transition duration-200"
            >
              <option value="">Pilih Agama</option>
              <option value="Islam">Islam</option>
              <option value="Kristen">Kristen</option>
              <option value="Katolik">Katolik</option>
              <option value="Hindu">Hindu</option>
              <option value="Buddha">Buddha</option>
              <option value="Konghucu">Konghucu</option>
            </select>
          </div>

          <!-- Nomor HP -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">
              Nomor HP/WhatsApp <span class="text-red-500">*</span>
            </label>
            <input
              type="tel"
              name="nomor_hp"
              required
              placeholder="081234567890"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-secondary focus:border-secondary transition duration-200"
            />
          </div>

          <!-- Email -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">
              Email <span class="text-red-500">*</span>
            </label>
            <input
              type="email"
              name="email"
              required
              placeholder="email@contoh.com"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-secondary focus:border-secondary transition duration-200"
            />
          </div>
        </div>

        <!-- Alamat Lengkap -->
        <div class="mt-6">
          <label class="block text-sm font-medium text-gray-700 mb-2">
            Alamat Lengkap <span class="text-red-500">*</span>
          </label>
          <textarea
            name="alamat_lengkap"
            required
            rows="4"
            placeholder="Masukkan alamat lengkap (jalan, RT/RW, kelurahan, kecamatan, kota)"
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-secondary focus:border-secondary transition duration-200"
          ></textarea>
        </div>
      </section>

      <!-- Data Pendidikan Sebelumnya -->
      <section class="bg-white p-6 rounded-xl shadow-lg border border-gray-100">
        <h2
          class="text-xl font-semibold mb-6 text-gray-800 border-l-4 border-secondary pl-3"
        >
          Data Pendidikan Sebelumnya
        </h2>

        <div class="space-y-6">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">
              Asal Sekolah <span class="text-red-500">*</span>
            </label>
            <input
              type="text"
              name="asal_sekolah"
              required
              placeholder="Nama sekolah sebelumnya"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-secondary focus:border-secondary transition duration-200"
            />
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">
              Alamat Asal Sekolah <span class="text-red-500">*</span>
            </label>
            <textarea
              name="alamat_sekolah"
              required
              rows="4"
              placeholder="Alamat lengkap sekolah sebelumnya"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-secondary focus:border-secondary transition duration-200"
            ></textarea>
          </div>
        </div>
      </section>

      <!-- Data Orang Tua -->
      <section class="bg-white p-6 rounded-xl shadow-lg border border-gray-100">
        <h2
          class="text-xl font-semibold mb-6 text-gray-800 border-l-4 border-secondary pl-3"
        >
          Data Orang Tua/Wali
        </h2>

        <div class="space-y-8">
          <!-- Data Ayah -->
          <div>
            <h3
              class="text-lg font-medium text-gray-700 mb-4 pb-2 border-b border-gray-200"
            >
              Data Ayah
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">
                  Nama Lengkap Ayah <span class="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  name="nama_ayah"
                  required
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-secondary focus:border-secondary transition duration-200"
                />
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">
                  Nomor Telepon Ayah <span class="text-red-500">*</span>
                </label>
                <input
                  type="tel"
                  name="telepon_ayah"
                  required
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-secondary focus:border-secondary transition duration-200"
                />
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">
                  Pekerjaan Ayah <span class="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  name="pekerjaan_ayah"
                  required
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-secondary focus:border-secondary transition duration-200"
                />
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">
                  Alamat Ayah <span class="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  name="alamat_ayah"
                  required
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-secondary focus:border-secondary transition duration-200"
                />
              </div>
            </div>
          </div>

          <!-- Data Ibu -->
          <div>
            <h3
              class="text-lg font-medium text-gray-700 mb-4 pb-2 border-b border-gray-200"
            >
              Data Ibu
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">
                  Nama Lengkap Ibu <span class="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  name="nama_ibu"
                  required
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-secondary focus:border-secondary transition duration-200"
                />
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">
                  Nomor Telepon Ibu <span class="text-red-500">*</span>
                </label>
                <input
                  type="tel"
                  name="telepon_ibu"
                  required
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-secondary focus:border-secondary transition duration-200"
                />
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">
                  Pekerjaan Ibu <span class="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  name="pekerjaan_ibu"
                  required
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-secondary focus:border-secondary transition duration-200"
                />
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">
                  Alamat Ibu <span class="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  name="alamat_ibu"
                  required
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-secondary focus:border-secondary transition duration-200"
                />
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Pernyataan -->
      <section class="bg-white p-6 rounded-xl shadow-lg border border-gray-100">
        <h2
          class="text-xl font-semibold mb-6 text-gray-800 border-l-4 border-secondary pl-3"
        >
          Pernyataan
        </h2>

        <div class="space-y-4 bg-gray-50 p-6 rounded-lg">
          <div class="flex items-start">
            <input
              type="checkbox"
              name="pernyataan_kebenaran"
              id="pernyataan_kebenaran"
              class="mt-1 mr-3 h-5 w-5 text-blue-600 border-gray-300 rounded focus:ring-secondary"
              required
            />
            <label for="pernyataan_kebenaran" class="text-gray-700">
              <span class="font-medium"
                >Data yang saya berikan adalah benar dan dapat
                dipertanggungjawabkan</span
              >
            </label>
          </div>

          <div class="flex items-start">
            <input
              type="checkbox"
              name="pernyataan_seleksi"
              id="pernyataan_seleksi"
              class="mt-1 mr-3 h-5 w-5 text-blue-600 border-gray-300 rounded focus:ring-secondary"
              required
            />
            <label for="pernyataan_seleksi" class="text-gray-700">
              <span class="font-medium"
                >Saya bersedia mengikuti proses seleksi pendaftaran sesuai
                jadwal</span
              >
            </label>
          </div>

          <div class="flex items-start">
            <input
              type="checkbox"
              name="pernyataan_keputusan"
              id="pernyataan_keputusan"
              class="mt-1 mr-3 h-5 w-5 text-blue-600 border-gray-300 rounded focus:ring-secondary"
              required
            />
            <label for="pernyataan_keputusan" class="text-gray-700">
              <span class="font-medium"
                >Saya memahami bahwa keputusan panitia pendaftaran adalah mutlak</span
              >
            </label>
          </div>
        </div>
      </section>

      <!-- Submit Button -->
      <div class="text-center">
        <button
          type="submit"
          id="submitBtn"
          class="px-8 py-4 text-white font-semibold rounded-lg focus:outline-none focus:ring-4 focus:ring-gray-300 focus:ring-offset-2 transition duration-300 text-lg shadow-lg hover:shadow-xl hover:opacity-90"
          style={`background-color: ${settings.primaryColor || "#2563eb"};`}
        >
          Kirim Pendaftaran
        </button>
      </div>
    </form>

    <!-- Result Modal -->
    <div
      id="resultModal"
      class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm hidden items-center justify-center z-50 p-4 transition-all"
    >
      <div
        class="bg-white rounded-[2rem] shadow-[0_20px_50px_-12px_rgba(0,0,0,0.3)] max-w-md w-full mx-auto transform transition-all relative overflow-hidden ring-1 ring-slate-100"
      >
        <!-- Close Button (X) -->
        <button
          onclick="window.closeModal()"
          class="absolute top-5 right-5 text-slate-400 hover:text-slate-700 hover:bg-slate-100/80 rounded-full transition-all p-2 z-10"
          aria-label="Close modal"
        >
          <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2.5"
              d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>

        <div class="px-8 pt-12 pb-8">
          <div class="text-center mb-6">
            <div
              id="modalIconSuccess"
              class="mx-auto hidden items-center justify-center h-24 w-24 rounded-full bg-gradient-to-br from-emerald-100 to-emerald-50 mb-6 shadow-sm ring-4 ring-emerald-50/50"
            >
              <svg
                class="h-12 w-12 text-emerald-500"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2.5"
                  d="M5 13l4 4L19 7"></path>
              </svg>
            </div>
            <div
              id="modalIconError"
              class="mx-auto hidden items-center justify-center h-24 w-24 rounded-full bg-gradient-to-br from-red-100 to-rose-50 mb-6 shadow-sm ring-4 ring-red-50/50"
            >
              <svg
                class="h-12 w-12 text-rose-500"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2.5"
                  d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </div>
            <h3
              id="modalTitle"
              class="text-3xl font-extrabold text-slate-800 tracking-tight"
            >
            </h3>
          </div>

          <p
            id="modalMessage"
            class="text-slate-500 mb-8 text-center leading-relaxed text-[15px]"
          >
          </p>

          <div id="registrationId" class="hidden">
            <!-- Space for dynamic ID injection -->
          </div>

          <div
            class="flex flex-col sm:flex-row space-y-3 sm:space-y-0 sm:space-x-3 mt-8"
          >
            <button
              onclick="window.closeModal()"
              class="w-full sm:flex-1 px-5 py-3.5 bg-white text-slate-600 font-semibold rounded-xl border border-slate-200 hover:bg-slate-50 hover:border-slate-300 focus:outline-none focus:ring-4 focus:ring-slate-100 transition-all duration-200"
            >
              Tutup
            </button>
            <a
              href="/pendaftaran/status"
              id="checkStatusBtn"
              class="hidden w-full sm:flex-1 px-5 py-3.5 bg-gradient-to-tr from-blue-600 to-indigo-600 font-semibold rounded-xl hover:from-blue-700 hover:to-indigo-700 focus:outline-none focus:ring-4 focus:ring-blue-100 shadow-md hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300 text-center"
            >
              <span class="text-white">Cek Status</span>
            </a>
          </div>
        </div>
      </div>
    </div>

    <script>
      function initRegistrationForm() {
        const form = document.getElementById(
          "registrationForm",
        ) as HTMLFormElement;
        const submitBtn = document.getElementById(
          "submitBtn",
        ) as HTMLButtonElement;
        const resultModal = document.getElementById("resultModal");
        const modalTitle = document.getElementById("modalTitle");
        const modalMessage = document.getElementById("modalMessage");
        const modalIconSuccess = document.getElementById("modalIconSuccess");
        const modalIconError = document.getElementById("modalIconError");
        const checkStatusBtn = document.getElementById("checkStatusBtn");
        const registrationIdDiv = document.getElementById("registrationId");
        const idValue = document.getElementById("idValue");

        // Deklarasi global agar onclick di HTML bekerja
        Object.assign(window, {
          closeModal: function () {
            if (resultModal) {
              resultModal.classList.add("hidden");
              resultModal.classList.remove("flex");
            }
          },
        });

        if (form) {
          // Hindari listener ganda jika script dieksekusi berkali-kali
          form.removeEventListener("submit", handleRegistrationSubmit);
          form.addEventListener("submit", handleRegistrationSubmit);

          async function handleRegistrationSubmit(e: SubmitEvent) {
            e.preventDefault();

            // 1. Disable submit button & state processing
            if (submitBtn) {
              submitBtn.disabled = true;
              submitBtn.innerHTML = `
              <svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-white inline-block" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
              Memproses...
            `;
            }

            try {
              const formData = new FormData(form);
              const data = Object.fromEntries(formData.entries());

              // API Endpoint
              const response = await fetch("/api/pendaftaran/register", {
                method: "POST",
                headers: {
                  "Content-Type": "application/json",
                },
                body: JSON.stringify(data),
              });

              const result = await response.json();

              // 2. Setup Modal Content based on result
              if (resultModal && modalTitle && modalMessage) {
                resultModal.classList.remove("hidden");
                resultModal.classList.add("flex");

                if (response.ok) {
                  // Sukses
                  modalTitle.textContent = "Pendaftaran Berhasil!";
                  modalMessage.textContent =
                    "Terima kasih, data Anda telah kami terima.";

                  if (modalIconSuccess)
                    modalIconSuccess.classList.remove("hidden");
                  if (modalIconSuccess) modalIconSuccess.classList.add("flex");
                  if (modalIconError) modalIconError.classList.add("hidden");
                  if (modalIconError) modalIconError.classList.remove("flex");

                  const kode =
                    result.data?.kode_pendaftaran ||
                    result.kode_pendaftaran ||
                    result.pendaftaran_id;
                  if (kode) {
                    if (kode) {
                      if (registrationIdDiv) {
                        registrationIdDiv.classList.remove("hidden");
                        registrationIdDiv.className =
                          "mb-8 space-y-5 animate-in fade-in slide-in-from-bottom-4 duration-700";

                        registrationIdDiv.innerHTML = `
                        <div class="relative group">
                          <div class="absolute -inset-1 bg-gradient-to-r from-blue-600 to-indigo-600 rounded-2xl blur opacity-20 group-hover:opacity-30 transition duration-1000"></div>
                          <div class="relative bg-slate-50 border border-slate-100 rounded-2xl p-6 text-center">
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] mb-3">
                              KODE PENDAFTARAN RESMI
                            </p>
                            <div class="relative">
                              <span id="idValue" class="text-3xl font-mono font-bold text-slate-800 tracking-tighter sm:tracking-normal selection:bg-indigo-100">
                                ${kode}
                              </span>
                            </div>
                          </div>
                        </div>

                        <div class="bg-indigo-50/50 border border-indigo-100 rounded-2xl p-5 flex items-start gap-4">
                          <div class="bg-indigo-100 rounded-xl p-2.5 shrink-0 shadow-sm">
                            <svg class="w-6 h-6 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path>
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path>
                            </svg>
                          </div>
                          <div>
                            <p class="text-[13px] font-bold text-indigo-900 leading-snug mb-1">
                              Simpan Kode Pendaftaran
                            </p>
                            <p class="text-[12px] text-indigo-700/80 leading-relaxed">
                              Mohon <span class="bg-indigo-200/50 px-1 rounded font-bold text-indigo-900">SCREENSHOT</span> halaman ini. Kode ini wajib digunakan untuk pengecekan status kelulusan Anda.
                            </p>
                          </div>
                        </div>
                      `;
                      }
                    }
                  }
                  if (checkStatusBtn) checkStatusBtn.classList.remove("hidden");

                  form.reset();
                } else {
                  // Error
                  modalTitle.textContent = "Pendaftaran Gagal";
                  modalMessage.textContent =
                    result.error || "Terjadi kesalahan saat memproses data.";

                  if (modalIconError) modalIconError.classList.remove("hidden");
                  if (modalIconError) modalIconError.classList.add("flex");
                  if (modalIconSuccess)
                    modalIconSuccess.classList.add("hidden");
                  if (modalIconSuccess)
                    modalIconSuccess.classList.remove("flex");

                  if (registrationIdDiv)
                    registrationIdDiv.classList.add("hidden");
                  if (checkStatusBtn) checkStatusBtn.classList.add("hidden");
                }
              }
            } catch (error) {
              console.error("Error submitting form:", error);

              if (resultModal && modalTitle && modalMessage) {
                resultModal.classList.remove("hidden");
                resultModal.classList.add("flex");

                modalTitle.textContent = "Koneksi Bermasalah";
                modalMessage.textContent =
                  "Tidak dapat terhubung ke server. Silakan coba lagi.";

                if (modalIconError) modalIconError.classList.remove("hidden");
                if (modalIconError) modalIconError.classList.add("flex");
                if (modalIconSuccess) modalIconSuccess.classList.add("hidden");
                if (modalIconSuccess) modalIconSuccess.classList.remove("flex");

                if (registrationIdDiv)
                  registrationIdDiv.classList.add("hidden");
                if (checkStatusBtn) checkStatusBtn.classList.add("hidden");
              }
            } finally {
              // 3. Restore Button State
              if (submitBtn) {
                submitBtn.disabled = false;
                submitBtn.innerHTML = "Kirim Pendaftaran";
              }
            }
          }
        }
      }

      // Execute immediately on script load
      initRegistrationForm();

      // Execute on view transitions (if used)
      document.addEventListener("astro:page-load", initRegistrationForm);

      // Execute when DOM is fully loaded as fallback
      document.addEventListener("DOMContentLoaded", initRegistrationForm);
    </script>
  </div>
</Layout>
